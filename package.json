{
  "name": "kqmd",
  "version": "0.1.0",
  "packageManager": "bun@1.3.10",
  "description": "qmd-compatible replacement distribution scaffold for Korean-focused search experiments",
  "type": "module",
  "bin": {
    "qmd": "./bin/qmd.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:parity": "vitest run test/owned-command-parity",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "measure:kiwi-reliability": "bun run scripts/measure_kiwi_search_reliability.ts",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "node-llama-cpp"
  ],
  "keywords": [
    "cli",
    "qmd",
    "markdown",
    "search"
  ],
  "license": "MIT",
  "dependencies": {
    "@tobilu/qmd": "2.0.1",
    "kiwi-nlp": "0.22.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "25.4.0",
    "@vitest/coverage-v8": "4.0.18",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
